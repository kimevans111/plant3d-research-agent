# OpenAI-compatible chat completion settings.
# Leave LLM_API_KEY empty to use the built-in mock provider.
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Frontend can point to a different backend if needed.
BACKEND_URL=http://localhost:8000

# RAG storage path. Chroma is used when available; otherwise a local JSON vector index is used.
RAG_PERSIST_DIR=.rag_index

# Use "simple" for the no-dependency JSON vector store, or "chroma" to force Chroma.
RAG_VECTOR_BACKEND=simple
