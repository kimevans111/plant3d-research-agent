{
  "skill_name": "rag_research_qa",
  "version": "0.1.0",
  "description": "Answer research-note and paper questions with retrieved context and citation metadata.",
  "categories": ["rag", "qa", "citation", "research_notes"],
  "recommended_tools": [
    "document_loader",
    "text_splitter",
    "retriever",
    "vector_store",
    "answer_generator",
    "citation_formatter"
  ],
  "required_fields": ["query"],
  "optional_fields": ["docs_dir", "top_k", "file_paths", "task_type"],
  "input_schema": {
    "type": "object",
    "properties": {
      "query": {"type": "string"},
      "docs_dir": {"type": ["string", "null"]},
      "top_k": {"type": "integer"},
      "file_paths": {"type": "array", "items": {"type": "string"}},
      "task_type": {"type": ["string", "null"]}
    }
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "answer": {"type": "string"},
      "citations": {"type": "array"},
      "retrieved_sources": {"type": "array", "items": {"type": "string"}},
      "used_tools": {"type": "array", "items": {"type": "string"}}
    }
  },
  "error_schema": {
    "code": "string",
    "message": "string",
    "recoverable": "boolean"
  }
}
